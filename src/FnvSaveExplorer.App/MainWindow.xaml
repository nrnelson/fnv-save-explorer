<Window x:Class="FnvSaveExplorer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnvSaveExplorer.App"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="600" Width="940">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Open…" Padding="10,2" Click="OnOpenClick"/>
            <Button Content="Save As…" Padding="10,2" Margin="4,0,0,0"
                    IsEnabled="{Binding HasSave}" Click="OnSaveAsClick"/>
            <Separator/>
            <Button Content="Save screenshot…" Padding="10,2"
                    IsEnabled="{Binding HasSave}" Click="OnSaveScreenshotClick"/>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding Status}"/>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: screenshot + character summary -->
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <Border BorderBrush="#FF555555" BorderThickness="1" Background="#FF1B1B1B"
                        Height="220" Margin="0,0,0,8">
                    <Image Source="{Binding Screenshot}" Stretch="Uniform" Margin="4"/>
                </Border>
                <GroupBox Header="Character">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PlayerName}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Title" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PlayerTitle}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Level" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Level}" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Location" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Location}" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Playtime" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Playtime}" Margin="0,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Save #" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SaveNumber}" Margin="0,2"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Language" Margin="0,2,12,2" Foreground="Gray"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Language}" Margin="0,2"/>
                    </Grid>
                </GroupBox>
            </StackPanel>

            <!-- Right: detail tabs -->
            <TabControl Grid.Column="1">
                <TabItem Header="Plugins">
                    <ListBox ItemsSource="{Binding Plugins}" FontFamily="Consolas" Margin="2"/>
                </TabItem>

                <TabItem Header="File Location Table (R&amp;D)">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="4" Foreground="Gray"
                                   Text="Raw uint32 values at the start of the save body. These are absolute file offsets and counts pointing into the globals / change-form / FormID-array sections — the gateway for decoding deeper data."/>
                        <DataGrid ItemsSource="{Binding FileLocationTable}" AutoGenerateColumns="False"
                                  IsReadOnly="True" HeadersVisibility="Column" FontFamily="Consolas" Margin="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="40"/>
                                <DataGridTextColumn Header="Decimal" Binding="{Binding Value}" Width="140"/>
                                <DataGridTextColumn Header="Hex" Binding="{Binding Hex}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Edit (safe)">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"
                                   Text="Only fixed-width / same-length edits are offered: these change values in place without shifting the file, so the undecoded body and its absolute offsets stay valid. Click Apply, then Save As to write a new file (the original is backed up)."/>
                        <TextBlock Text="Player name (same length only)"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="240" HorizontalAlignment="Left"/>
                        <TextBlock Text="Level"/>
                        <TextBox Text="{Binding EditLevel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="Save number"/>
                        <TextBox Text="{Binding EditSaveNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="Caps"/>
                        <TextBox Text="{Binding EditCaps, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="Karma"/>
                        <TextBox Text="{Binding EditKarma, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="XP"/>
                        <TextBox Text="{Binding EditXp, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Width="120" HorizontalAlignment="Left"/>
                        <TextBlock Text="SPECIAL" Margin="0,4,0,2"/>
                        <DataGrid ItemsSource="{Binding Special}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  HeadersVisibility="Column" Width="240" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" IsReadOnly="True" Width="140"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Apply staged edits" Padding="10,3" HorizontalAlignment="Left" Click="OnApplyClick"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Skills">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding SkillsInfo}"/>
                        <DataGrid ItemsSource="{Binding Skills}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  HeadersVisibility="Column" Width="260" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Skill" Binding="{Binding Name}" IsReadOnly="True" Width="160"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Apply staged edits" Padding="10,3" HorizontalAlignment="Left" Click="OnApplyClick"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Inventory">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding InventoryInfo}"/>
                        <DataGrid ItemsSource="{Binding Inventory}" AutoGenerateColumns="False" CanUserAddRows="False"
                                  HeadersVisibility="Column" FontFamily="Consolas" Width="820" HorizontalAlignment="Left"
                                  MaxHeight="340" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="170"/>
                                <DataGridTextColumn Header="Tab (type)" Binding="{Binding Tab}" IsReadOnly="True" Width="120"/>
                                <DataGridTextColumn Header="Item (FormID)" Binding="{Binding Item}" IsReadOnly="True" Width="150"/>
                                <DataGridTextColumn Header="Source (mod)" Binding="{Binding Source}" IsReadOnly="True" Width="130"/>
                                <DataGridTextColumn Header="Count" Binding="{Binding Count, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                <DataGridCheckBoxColumn Header="Equipped" Binding="{Binding Equipped}" IsReadOnly="True" Width="70"/>
                                <DataGridTextColumn Header="Condition" Binding="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridTextColumn Header="Max" Binding="{Binding MaxCondition}" IsReadOnly="True" Width="70"/>
                                <DataGridTextColumn Header="%" Binding="{Binding ConditionPercent}" IsReadOnly="True" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Game Data folder (base game + DLC)" Foreground="Gray"/>
                        <DockPanel Width="700" HorizontalAlignment="Left" Margin="0,2,0,6">
                            <Button DockPanel.Dock="Right" Content="Browse…" Padding="10,3" Margin="6,0,0,0" Click="OnBrowseDataFolderClick"/>
                            <TextBox Text="{Binding EditDataFolder, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="Mod Organizer 2 mods folder (optional — for modded saves; auto-filled from an MO2 save)" Foreground="Gray"/>
                        <DockPanel Width="700" HorizontalAlignment="Left" Margin="0,2,0,10">
                            <Button DockPanel.Dock="Right" Content="Resolve names" Padding="10,3" Margin="6,0,0,0" Click="OnResolveNamesClick"/>
                            <Button DockPanel.Dock="Right" Content="Browse…" Padding="10,3" Margin="6,0,0,0" Click="OnBrowseModsFolderClick"/>
                            <TextBox Text="{Binding EditModsFolder, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                        </DockPanel>
                        <Button Content="Apply staged edits" Padding="10,3" HorizontalAlignment="Left" Click="OnApplyClick"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Notes">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding NotesInfo}"/>
                        <DataGrid ItemsSource="{Binding Notes}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontFamily="Consolas"
                                  Width="700" HorizontalAlignment="Left" MaxHeight="400">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Media}" Width="60"/>
                                <DataGridTextColumn Header="Note" Binding="{Binding Name}" Width="300"/>
                                <DataGridTextColumn Header="FormID" Binding="{Binding Note}" Width="160"/>
                                <DataGridTextColumn Header="Source (mod)" Binding="{Binding Source}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Perks">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding PerksInfo}"/>
                        <DataGrid ItemsSource="{Binding Perks}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontFamily="Consolas"
                                  Width="660" HorizontalAlignment="Left" MaxHeight="440">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Perk / Trait" Binding="{Binding Name}" Width="280"/>
                                <DataGridTextColumn Header="Rank" Binding="{Binding RankText}" Width="50"/>
                                <DataGridTextColumn Header="FormID" Binding="{Binding Form}" Width="160"/>
                                <DataGridTextColumn Header="Source (mod)" Binding="{Binding Source}" Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Reputation">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding ReputationInfo}"/>
                        <DataGrid ItemsSource="{Binding Reputation}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontFamily="Consolas"
                                  Width="520" HorizontalAlignment="Left" MaxHeight="440">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Faction" Binding="{Binding Faction}" Width="240"/>
                                <DataGridTextColumn Header="Fame" Binding="{Binding Fame}" Width="70"/>
                                <DataGridTextColumn Header="Infamy" Binding="{Binding Infamy}" Width="70"/>
                                <DataGridTextColumn Header="FormID" Binding="{Binding Form}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Globals">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding GlobalsInfo}"/>
                        <DataGrid ItemsSource="{Binding Globals}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontFamily="Consolas"
                                  Width="560" HorizontalAlignment="Left" MaxHeight="460">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Global (GLOB)" Binding="{Binding Name}" Width="280" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="120"/>
                                <DataGridTextColumn Header="FormID" Binding="{Binding Form}" Width="120" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Quests">
                    <StackPanel Margin="10" IsEnabled="{Binding HasSave}">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10" Text="{Binding QuestsInfo}"/>
                        <DataGrid ItemsSource="{Binding Quests}" AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" HeadersVisibility="Column" FontFamily="Consolas"
                                  Width="780" HorizontalAlignment="Left" MaxHeight="460"
                                  RowDetailsVisibilityMode="VisibleWhenSelected">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <!-- Completed quests show greyed, matching the in-game Pip-Boy. -->
                                        <DataTrigger Binding="{Binding State}" Value="Completed">
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Failed">
                                            <Setter Property="Foreground" Value="#B00020"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Quest" Binding="{Binding Name}" Width="320"/>
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90"/>
                                <DataGridTextColumn Header="Objectives" Binding="{Binding Progress}" Width="100"/>
                                <DataGridTextColumn Header="FormID" Binding="{Binding FormIdHex}" Width="120"/>
                            </DataGrid.Columns>
                            <DataGrid.RowDetailsTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Lines}" Margin="24,4,0,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontFamily="Consolas" Foreground="#333"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGrid.RowDetailsTemplate>
                        </DataGrid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Misc Stats">
                    <DataGrid ItemsSource="{Binding MiscStats}" AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" FontFamily="Consolas" Margin="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Change Forms (R&amp;D)">
                    <DockPanel Margin="8" IsEnabled="{Binding HasSave}">
                        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="2,0,2,6" Foreground="Gray"
                                   Text="{Binding ChangeFormsInfo}"/>
                        <DockPanel DockPanel.Dock="Top" Margin="2,0,2,6">
                            <TextBlock DockPanel.Dock="Left" Text="Filter" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding ChangeFormFilter, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center"/>
                        </DockPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <DataGrid Grid.Column="0" ItemsSource="{Binding ChangeForms}"
                                      SelectedItem="{Binding SelectedChangeForm}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                                      FontFamily="Consolas" EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Offset" Binding="{Binding OffsetHex}" Width="90"/>
                                    <DataGridTextColumn Header="iref" Binding="{Binding Iref}" Width="60"/>
                                    <DataGridTextColumn Header="FormID" Binding="{Binding FormIdHex}" Width="100"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="120"/>
                                    <DataGridTextColumn Header="Len" Binding="{Binding DataLength}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#FF3A3A3A"/>
                            <Border Grid.Column="2" BorderBrush="#FF555555" BorderThickness="1" Background="#FF1B1B1B">
                                <TextBox Text="{Binding ChangeFormWalk, Mode=OneWay}" IsReadOnly="True"
                                         FontFamily="Consolas" Foreground="#FFDDDDDD" Background="Transparent"
                                         BorderThickness="0" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                            </Border>
                        </Grid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Body">
                    <TextBlock Text="{Binding BodyInfo}" TextWrapping="Wrap" Margin="10" FontFamily="Consolas"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
